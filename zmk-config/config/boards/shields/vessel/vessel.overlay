/*
 * Vessel trackball — device tree for XIAO nRF52840 (Sense Plus)
 *
 * XIAO D-pin  ->  nRF port/pin  (used below)
 *   D0=P0.02  D1=P0.03  D2=P0.28  D3=P0.29  D4=P0.04  D5=P0.05
 *   D6=P1.11  D7=P1.12  D8=P1.13  D9=P1.14  D10=P1.15
 * The 9 extra Sense-Plus castellated pads are NOT in this map — look up their
 * P0.xx/P1.xx numbers on the Seeed pinout and add them where marked TODO.
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/kscan_mock.h>
/* PMW3610 node below uses INPUT_EV_REL / INPUT_REL_X/Y — the seed referenced
 * these without including the header that defines them, so a fresh build never
 * compiled. (Per the badjeff driver README.) */
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    /* v1 work item 1: D0/D1 are NOT buttons. In the cap-touch revision they are
     * the CAP1188 ALERT (D0) and RESET (D1) — see FIRMWARE_SPEC.md §2. The old
     * `zmk,kscan-gpio-direct` on D0/D1 is deleted.
     *
     * This device has no digital-GPIO keys at all now (the 6 touch zones arrive
     * in PR-2 as a CAP1188 *input* device, not a kscan). ZMK still requires a
     * chosen `zmk,kscan`, so stand in a mock that never fires: no `events` and
     * no `exit-after`, so it generates nothing on real hardware. PR-2 removes it
     * once the touch input pipeline exists. Mirrors ZMK's own native_posix mock
     * pattern (rows/columns, no events). */
    kscan0: kscan_mock {
        compatible = "zmk,kscan-mock";
        rows = <1>;
        columns = <1>;
        /* The mock driver requires an `events` property to exist (it sizes an
         * array by its length). One press+release on position (0,0) — which is
         * bound to &none — is a boot-time no-op, then the driver idles (no
         * `exit-after`, which would reboot real hardware). PR-2 removes all of
         * this once the CAP1188 input pipeline exists. */
        events = <ZMK_MOCK_PRESS(0,0,10) ZMK_MOCK_RELEASE(0,0,10)>;
    };

    /* Scroll ring: the 2 hall latches read as a quadrature encoder */
    scroll: encoder_scroll {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 28 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;  /* D2 hall A */
        b-gpios = <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;  /* D3 hall B */
        steps = <24>;
        status = "okay";
    };
    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&scroll>;
    };

    /* Register trackball motion with the pointing subsystem */
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
    };
};

/* --- PMW3610 on SPI (3-wire) — needs the badjeff module in west.yml --- */
&pinctrl {
    spi_tb_default: spi_tb_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK,  1, 13)>,   /* D8  SCLK */
                    <NRF_PSEL(SPIM_MOSI, 1, 15)>,   /* D10 SDIO (data) */
                    /* 3-wire sensor: no separate MISO wire. Park MISO on an
                     * unused pin so Zephyr is happy; the driver reads on MOSI. */
                    <NRF_PSEL(SPIM_MISO, 0,  6)>;
        };
    };
    spi_tb_sleep: spi_tb_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK,  1, 13)>,
                    <NRF_PSEL(SPIM_MOSI, 1, 15)>,
                    <NRF_PSEL(SPIM_MISO, 0,  6)>;
            low-power-enable;
        };
    };
};

/* PMW3610 lives on SPIM3, NOT SPIM1. On the nRF52840, spi1 (SPIM1) and i2c1
 * (TWIM1) are the SAME peripheral instance (both at 0x40004000) and are mutually
 * exclusive. The CAP1188 touch bus must be i2c1 (the XIAO D4/D5 controller), so
 * the trackball SPI moves to spi3 (SPIM3 @0x4002f000, instance 3, no TWI sibling).
 * Pins are unchanged — pinctrl (spi_tb_default) routes the same D8/D9/D10. */
&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi_tb_default>;
    pinctrl-1 = <&spi_tb_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio1 14 GPIO_ACTIVE_LOW>;          /* D9 nCS */

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610-alt";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio1 12 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;  /* D7 MOT */
        cpi = <600>;
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
        /* Uncomment/adjust after the first test to fix direction: */
        /* swap-xy; invert-x; invert-y; */
    };
};

/* --- CAP1188 8-channel capacitive touch (work item 2) ---
 * Shared I2C with the DRV2605L haptics (added in item 5). On the xiao_ble board
 * the XIAO D4/D5 pins are &i2c1 (NOT i2c0 — that's the internal sensor bus).
 * The spec's "I2C0 @0x29" is a net label; the Zephyr node here is i2c1.
 * The driver emits an INPUT_EV_KEY event per channel (codes below); the
 * input-listener + input-processor-behaviors in vessel.keymap turn those into
 * ZMK behaviors — no custom module needed (spec §4.2 primary path).
 */
&i2c1 {
    status = "okay";

    cap1188: cap1188@29 {
        compatible = "microchip,cap12xx";
        reg = <0x29>;
        /* D0 = P0.02 = CAP1188 ALERT (open-drain, active low). Internal pull-up
         * enabled; the harness may also pull it up. D1/RESET is tied high in
         * hardware (spec §2), so it is not driven here. */
        int-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        /* One input code per physical channel CS1..CS8 -> touch channel 0..7.
         * The keymap maps these to behaviors. */
        input-codes = <INPUT_BTN_0 INPUT_BTN_1 INPUT_BTN_2 INPUT_BTN_3
                       INPUT_BTN_4 INPUT_BTN_5 INPUT_BTN_6 INPUT_BTN_7>;
        /* repeat;  // auto-repeat on prolonged touch — left off for click zones */
    };
};
