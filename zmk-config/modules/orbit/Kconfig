# ORBit repo-local Zephyr module. Home for the small pieces of custom firmware
# the spec's work package needs and ZMK doesn't ship: the slider chord input
# processor (item 4) and, later, the DRV2605L haptics driver (item 5).

config ORBIT_INPUT_PROCESSOR_CHORD
	bool "ORBit two-pad chord input processor"
	default y
	depends on DT_HAS_ORBIT_INPUT_PROCESSOR_CHORD_ENABLED
	depends on INPUT
	help
	  Input processor that turns a near-simultaneous touch of two EV_KEY
	  codes into a single third code (spec: CS7+CS8 slider chord = mute),
	  while single touches pass through with a short detection delay.

config ORBIT_HAPTIC_FEEDBACK
	bool "ORBit touch-zone haptic feedback (DRV2605L)"
	default y
	depends on DT_HAS_ORBIT_HAPTIC_FEEDBACK_ENABLED
	depends on HAPTICS_DRV2605
	depends on SETTINGS
	depends on INPUT
	help
	  Plays a DRV2605 ROM library effect per touch-zone press, and runs the
	  LRA auto-calibration once at boot, persisting the result via settings
	  (spec item 5: init + auto-cal at boot with persist, per-zone effect,
	  touch-to-haptic < 10 ms).

config ORBIT_GLOW
	bool "ORBit SK6812 glow engine"
	default y
	depends on DT_HAS_ORBIT_GLOW_ENABLED
	depends on LED_STRIP
	depends on INPUT
	help
	  Amber glow scenes on the SK6812 chain (spec item 6): low-duty idle,
	  zone flash on touch, breathe hook for item 7's wake mask, all-off on
	  ZMK idle/sleep. Subscribes to ZMK activity events.
